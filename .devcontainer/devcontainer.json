{
  "name": "Clawg Mission Control",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "forwardPorts": [3000, 5173, 18789],
  "portsAttributes": {
    "3000": { "label": "Mission Control UI", "onAutoForward": "notify", "visibility": "public" },
    "5173": { "label": "Vite Dev Server", "onAutoForward": "notify", "visibility": "public" },
    "18789": { "label": "OpenClaw Gateway", "onAutoForward": "notify", "visibility": "public" }
  },
  "postCreateCommand": "npm install && cd ui && npm install && npm run build && cd ..",
  "postStartCommand": "cd ui && npx vite preview --host 0.0.0.0 --port 3000 &",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
